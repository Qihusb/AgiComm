# AgiComm API Keys
ZHIPU_API_KEY=your_zhipu_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here
OPENAI_API_KEY=your_openai_key_here

# 当前默认使用的提供商: zhipu / deepseek / openai
PRIMARY_PROVIDER=zhipu

# ===== 服务器配置 =====
# 后端服务端口
API_PORT=8001

# 后端服务主机（0.0.0.0 表示接受任意 IP）
API_HOST=0.0.0.0

# 工作目录（确保相对路径正确）
WORK_DIR=./

# ===== 执行参数 =====
# Gunicorn 工作进程数（建议：CPU核数 * 2 + 1）
GUNICORN_WORKERS=4

# 请求超时时间（秒）
REQUEST_TIMEOUT=120

# ===== 日志级别 =====
# 可选: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ===== CORS 配置 =====
# 允许的前端域名（逗号分隔）
CORS_ORIGINS=*

# ===== 功能开关 =====
# 是否启用 API 文档 (/docs)
ENABLE_DOCS=true

# 是否启用前端静态文件服务
ENABLE_FRONTEND=true
